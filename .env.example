# ─────────────────────────────────────────────────────────────────────────────
# Project Zomboid Dedicated Server — Configuration
# Copy this file to .env and edit to your needs.
# ─────────────────────────────────────────────────────────────────────────────

# ── User / Group ─────────────────────────────────────────────────────────────
# UID and GID the server process runs as. Bind-mount directories will be
# owned by this user. Run `id` on the host to find your UID/GID.
PUID=1000
PGID=1000

# ── Server Identity ───────────────────────────────────────────────────────────
SERVER_NAME=zomboid
ADMIN_PASSWORD=changeme

# ── Network ───────────────────────────────────────────────────────────────────
SERVER_PORT=16261
# SERVER_PORT_2 is automatically set to SERVER_PORT + 1; override if needed
SERVER_PORT_2=16262
RCON_PORT=27015

# ── Memory ────────────────────────────────────────────────────────────────────
# JVM heap size for the server process. Sets both -Xms and -Xmx.
# Use m for megabytes or g for gigabytes (e.g. 4096m, 6g, 8g).
MEMORY=8192m

# ── Steam / Updates ───────────────────────────────────────────────────────────
# Set to false to skip SteamCMD on every container restart (faster boots).
# The server will still install on first run.
UPDATE_ON_START=true

# Mod update behaviour on start:
#   true  — smart update (default): checks Steam timestamps, only re-downloads
#           mods that have been updated since the last download. Fast when mods
#           haven't changed; automatically picks up new mod versions.
#   false — skip already-present mods entirely (fastest restarts, no Steam API call)
#   force — re-download every mod unconditionally (old UPDATE_MODS=true behaviour)
UPDATE_MODS=true

# Target a specific beta branch. Leave empty for the default public release.
# Common values: iwbums (unstable beta), b41multiplayer (B41 MP), b40 (legacy)
BETA_BRANCH=

# Steam credentials — optional, anonymous login is used if not set.
# Only needed if you hit download errors or want to use a specific Steam account.
STEAM_USERNAME=
STEAM_PASSWORD=

# ── Mods — Steam Collection ───────────────────────────────────────────────────
# Paste the numeric collection ID from the Steam Workshop URL.
# e.g. https://steamcommunity.com/sharedfiles/filedetails/?id=2982072751
#      → STEAM_COLLECTION_ID=2982072751
STEAM_COLLECTION_ID=

# Additional workshop item IDs to include alongside the collection (comma-separated).
# Useful for one-off mods not in your collection.
EXTRA_WORKSHOP_IDS=

# ── Scheduled Restart ─────────────────────────────────────────────────────────
# Automatically restart the server on a schedule so mod updates and server
# patches are applied without manual intervention.
#
# RESTART_SCHEDULE formats:
#   HH:MM  — restart daily at that local time (e.g. 04:00 for 4 AM)
#             Set TZ= in your environment to control the timezone.
#   Xh     — restart every X hours from container start (e.g. 6h, 12h)
#   Xm     — restart every X minutes (e.g. 30m — useful for testing)
#   (empty) — no scheduled restart
#
# RESTART_WARN_MINUTES: how many minutes before the restart to start warning
#   players. Warnings are sent at 10 min, 5 min, and 1 min marks (whichever
#   fall within the configured window).
#
# RCON_PASSWORD: set this to enable in-game countdown messages. The same value
#   is automatically written to the server's RCONPassword= setting.
#   Leave blank to restart silently (server still restarts, just no warnings).
RESTART_SCHEDULE=
RESTART_WARN_MINUTES=10
RCON_PASSWORD=

# ── Mod Update Watcher ────────────────────────────────────────────────────────
# Periodically polls Steam for mod updates and restarts the server automatically
# when a newer version of any workshop item is detected.
#
# A single batched API request covers all mods regardless of collection size.
# Steam's documented limit is 100,000 calls/day; at the 10-minute default this
# uses ~144 calls/day. On HTTP 429 the interval backs off exponentially
# (doubles each time, capped at 1 hour, ±10% jitter) and resets on success.
#
# MOD_UPDATE_CHECK: set to false to disable the watcher entirely.
# MOD_CHECK_INTERVAL: how often to query Steam — Xh, Xm, or Xs (e.g. 10m, 1h).
#   Recommended minimum: 5m. Going below 1m risks hitting rate limits.
MOD_UPDATE_CHECK=true
MOD_CHECK_INTERVAL=10m

# ── Server Properties (PZ_INI_ prefix) ───────────────────────────────────────
# Each PZ_INI_Key=Value maps directly to Key=Value in the server .ini file.
# Keys are case-sensitive and match the PZ property names exactly.
# Mods and WorkshopItems are auto-populated from the collection; set manually
# here only if not using a Steam collection.

PZ_INI_Public=false
PZ_INI_PublicName=My PZ Server
PZ_INI_PublicDescription=
PZ_INI_MaxPlayers=8
PZ_INI_Password=
PZ_INI_PauseEmpty=true
PZ_INI_GlobalChat=true
PZ_INI_Open=false
PZ_INI_PVP=false

# ── Map ───────────────────────────────────────────────────────────────────────
# Default map. For custom maps, list the mod map name first, then the base map,
# semicolon-separated. The mod workshop item must be in your collection or
# EXTRA_WORKSHOP_IDS. The map folder name comes from the mod (check mod.info).
#   Single map:  PZ_INI_Map=Muldraugh, KY
#   Custom map:  PZ_INI_Map=Bedford_Falls;Muldraugh, KY
PZ_INI_Map=Muldraugh, KY

# Backups
PZ_INI_BackupsCount=5
PZ_INI_BackupsOnVersionChange=true

# Anti-cheat (disable for modded servers if mods trigger false positives)
PZ_INI_AntiCheatProtectionType1=true
PZ_INI_AntiCheatProtectionType2=true
PZ_INI_AntiCheatProtectionType3=true
PZ_INI_AntiCheatProtectionType4=true

# Auto-save interval in minutes (0 = disabled, saves on exit only)
PZ_INI_SaveWorldEveryMinutes=20

# Show all players on the in-game map
PZ_INI_MapAllPlayers=true

# Automatically add connecting players to the whitelist
PZ_INI_AutoCreateUserInWhiteList=true

# Delete all trash/garbage items from the world periodically
PZ_INI_TrashDeleteAll=true

# Hours before zombie corpses are removed (0 = never)
PZ_INI_HoursForRottingBodyRemoval=24

# Misc
PZ_INI_DisplayUserName=true
PZ_INI_ShowFirstAndLastName=false
PZ_INI_PingLimit=400
PZ_INI_UPnP=false
PZ_INI_SleepAllowed=false
PZ_INI_SleepNeeded=false
PZ_INI_SafetySystem=true
PZ_INI_SafetyToggleTimer=100
PZ_INI_SafetyCooldownTimer=120

# Leave these blank — they are auto-populated from your Steam collection
PZ_INI_Mods=
PZ_INI_WorkshopItems=

# ── Sandbox Variables (PZ_SBX_ prefix) ───────────────────────────────────────
# These map to SandboxVars.lua. Numeric values only (PZ uses integers for enums).
# See https://pzwiki.net/wiki/Server_Settings for value meanings.

# Zombie population: 1=Insane 2=Very High 3=High 4=Normal 5=Low 6=None
PZ_SBX_Zombies=3

# Zombie distribution: 1=Urban Focused 2=Uniform
PZ_SBX_Distribution=1

# Day length: 1=15min 2=30min 3=1hr 4=2hr 5=3hr 6=5hr 7=12hr 8=1day
PZ_SBX_DayLength=3

# Starting conditions
PZ_SBX_StartYear=1
PZ_SBX_StartMonth=7
PZ_SBX_StartDay=1
# Start time: 1=7am 2=9am 3=12pm 4=2pm 5=5pm 6=9pm 7=12am 8=2am
PZ_SBX_StartTime=2

# Utility shutoff: 0=Instant 1=0-30 days 2=0-2 months 3=0-6 months 4=2-6 months 5=Years 6=Never
PZ_SBX_WaterShut=2
PZ_SBX_ElecShut=2

# Loot: 1=None 2=Scarce 3=Normal 4=Abund. 5=Insane
PZ_SBX_Loot=3
PZ_SBX_FoodLoot=3
PZ_SBX_WeaponLoot=3
PZ_SBX_OtherLoot=3

# Weather
PZ_SBX_Temperature=2
PZ_SBX_Rain=2
PZ_SBX_SunnyDays=2
PZ_SBX_RainFall=2

# Erosion speed: 1=Fast 2=Normal 3=Slow 4=Very Slow 5=Years 6=Disabled
PZ_SBX_ErosionSpeed=2

# XP multiplier (float stored as string; script handles quoting)
PZ_SBX_XpMultiplier=1.0

# Zombie respawn hours (0 = never)
PZ_SBX_ZombieRespawn=0

# Nature abundance: 1=Flourishing 2=Abundant 3=Normal 4=Poor 5=Barren
PZ_SBX_NatureAbundance=3

# Alarm frequency: 1=Never 2=Extremely Rare 3=Rare 4=Sometimes 5=Often 6=Very Often
PZ_SBX_Alarm=3

# Locked houses: 1=Never 2=Rarely 3=Sometimes 4=Often 5=Very Often
PZ_SBX_LockedHouses=3

# Book reading speed in minutes per page (lower = faster; vanilla default ~1-2 min/page)
PZ_SBX_MinutesPerPage=0.01

# Zombie infection transmission: 1=Blood+Saliva 2=Saliva Only (bites) 3=Everyone 4=None
PZ_SBX_ZombieTransmission=2
